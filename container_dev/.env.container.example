# Container configuration — copy to .env.container and customize
# This file is checked in; .env.container is gitignored.

IMAGE_NAME=ray-dev
CONTAINER_NAME=ray-dev-container
WORK_FOLDER=work

# Origin URL for the raymond repo — cloned bare inside the container by init.sh
ORIGIN_URL=https://github.com/vector76/raymond.git

# Exposed ports (host port = container port; change host side only if conflicts)
RAYMOND_PORT=7100
BEADS_PORT=7101

# Persist Claude Code auth across rebuilds (mounts ~/.claude and ~/.claude.json)
# Uncomment and set a local folder name; rebuild.bat creates it automatically.
# CLAUDE_PERSIST_FOLDER=claude_persist

# Persist the entire devuser home directory across rebuilds (slower; use CLAUDE_PERSIST_FOLDER instead)
# HOME_FOLDER=devuser_home
